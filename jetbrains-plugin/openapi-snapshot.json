{
  "openapi": "3.0.3",
  "info": {
    "title": "Correct by Construction Sidecar API",
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Health check"
      }
    },
    "/runs": {
      "get": {
        "summary": "List run summaries",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          }
        ]
      }
    },
    "/runs/{run_id}": {
      "get": {
        "summary": "Get one run review payload",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/benchmarks": {
      "get": {
        "summary": "List benchmark summaries",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 50
            }
          }
        ]
      }
    }
  }
}
