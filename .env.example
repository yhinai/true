# Copy to .env and fill in. .env is gitignored.
# Supabase (optional ledger mirror)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Direct Postgres connection (used by migrations / writer if preferred over REST)
POSTGRES_URL=postgres://postgres.YOUR-PROJECT-REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Vercel (only needed if deploying from this machine)
VERCEL_TOKEN=vcp_...

# Web app (Next.js) public vars
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Where the web app reads the CBC API (FastAPI from `uv run cbc-api`)
NEXT_PUBLIC_CBC_API_URL=http://localhost:8000
